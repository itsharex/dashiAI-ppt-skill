{
  "name": "guizang-ppt-skill",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:update": "node scripts/update-project-docs.mjs",
    "render:deck": "tsx scripts/render-deck.jsx",
    "render:goal": "tsx scripts/render-goal-deck.jsx",
    "render:all-layouts": "tsx scripts/render-deck.jsx examples/component-decks/all-layouts-showcase.jsx output/all-components-showcase/ppt/index.html",
    "showcase:update": "node scripts/validate-layout-showcase.mjs && npm run render:all-layouts && npm run validate:swiss -- output/all-components-showcase/ppt/index.html",
    "render:demo": "tsx scripts/render-deck.jsx examples/component-decks/all-layouts-showcase.jsx output/component-demo/ppt/index.html",
    "render:examples": "npm run render:demo",
    "validate:swiss": "node scripts/validate-swiss-deck.mjs",
    "test": "npm run render:demo && npm run validate:swiss -- output/component-demo/ppt/index.html"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unicornstudio-react": "^2.1.9"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
